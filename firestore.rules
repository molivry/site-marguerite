rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Données privées utilisateur
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Cartes personnelles (marqueurs + maps metadata)
    match /user_maps/{uid}/markers/{markerId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    // Métadonnées des cartes : lisibles par tous les membres (pour les demandes d'accès)
    match /user_maps/{uid}/maps/{mapId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Profils publics (prénom visible par tous les membres)
    match /user_profiles/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Posts du fil d'actualité
    match /activity_posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == resource.data.uid;

      // Réactions "J'ai bu ça aussi !"
      match /reactions/{uid} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Commentaires
      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
      }
    }

    // Relations d'abonnement (follows)
    match /follows/{uid}/following/{targetUid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Demandes d'accès aux cartes
    match /map_access_requests/{requestId} {
      allow create: if request.auth != null;
      allow read:   if request.auth != null &&
                       (resource.data.fromUid == request.auth.uid ||
                        resource.data.toUid   == request.auth.uid);
      allow update: if request.auth != null && resource.data.toUid == request.auth.uid;
    }

    // Messagerie privée
    match /conversations/{convId} {
      allow read, write: if request.auth != null &&
                            request.auth.uid in resource.data.participants;
      allow create: if request.auth != null;

      match /messages/{msgId} {
        allow read, write: if request.auth != null;
      }
    }

  }
}
